# Auto detect text files and perform LF normalization
* text=auto

# Python files - force LF
*.py text eol=lf

# Shell scripts - force LF
*.sh text eol=lf
*.ps1 text eol=lf

# Markdown - force LF
*.md text eol=lf

# YAML config - force LF
*.yaml text eol=lf
*.yml text eol=lf

# JSON data - force LF
*.json text eol=lf

# HTML/CSS/JS - force LF
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# CSV data files - force LF
*.csv text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.xlsx binary
